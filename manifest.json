{
  "manifest_version": 3,
  "name": "ChatGPT Memo Marker",
  "version": "0.2.0",
  "description": "ChatGPTのメッセージを保存し、自分用メモを追加できます。",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
